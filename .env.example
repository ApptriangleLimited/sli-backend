DATABASE_URL=postgresql://postgres:password@localhost:5432/project_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=1800
UPLOAD_ROOT=./uploads
MAX_UPLOAD_BYTES=26214400
JWT_SECRET_KEY=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REMEMBER_ME_ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Optional: regex for extra origins (e.g. Vercel previews). Leave empty to disable.
# CORS_ORIGIN_REGEX=https://([a-z0-9-]+\.)*vercel\.app
