                  "try {",
                  "  const r = pm.response.json();",
                  "  if (r.success && r.data && r.data.proposal) {",
                  "    pm.collectionVariables.set('proposal_id', String(r.data.proposal.id));",
                  "    const docs = r.data.proposal.documents;",
                  "    if (docs && docs.length) {",
