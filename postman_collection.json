    {
      "name": "Profile",
      "description": "Requires Bearer token (any authenticated role). PATCH updates name, phone, and/or avatar; GET /avatar returns the profile image file.",
      "item": [
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "type": "text",
                  "value": "Updated Name",
                  "description": "Optional"
                },
                {
                  "key": "phone",
                  "type": "text",
                  "value": "+8801712345678",
                  "description": "Optional"
                },
                {
                  "key": "remove_avatar",
                  "type": "text",
                  "value": "false",
                  "description": "Set true to delete current avatar"
                },
                {
                  "key": "avatar",
                  "type": "file",
                  "src": [],
                  "description": "Optional JPEG/PNG/WebP"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "profile"]
            },
            "description": "Multipart form-data. Send only fields you want to change. Response data.user includes phone and has_profile_image."
          },
          "response": []
        },
        {
          "name": "Get Profile Avatar",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/avatar",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", "avatar"]
            },
            "description": "Returns raw image bytes (404 if user has no avatar). Use after login when has_profile_image is true."
          },
          "response": []
        }
      ]
    },
