    {
      "name": "Agent proposals",
      "description": "Requires Bearer token for role **agent**. Multipart create uses application_documents[], applicant_documents[] (types: photo, signature, nid, birth_certificate, driving_license, passport, ssc_certificate), optional nominees[] and guardian_documents[]. See docs/PROPOSAL_CREATE_API_DOCUMENT_SECTIONS.txt.",
      "item": [
        {
          "name": "Create Proposal (minimal)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const r = pm.response.json();",
                  "  if (r.success && r.data && r.data.proposal) {",
                  "    pm.collectionVariables.set('proposal_id', String(r.data.proposal.id));",
                  "    const docs = r.data.proposal.documents;",
                  "    if (docs && docs.length) {",
                  "      pm.collectionVariables.set('document_id', String(docs[0].id));",
                  "    }",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ],
